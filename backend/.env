# ============================================================
# SETUP GUIDE
# ============================================================

# ─── Step 1: Packages install karo ───────────────────────────
# pip install google-ads facebook-business

# ─── Step 2: Google Ads Setup ────────────────────────────────
# 1. ads.google.com pe apna account open karo
# 2. Tools → API Center → Developer Token copy karo
# 3. console.cloud.google.com → New Project → Google Ads API enable
# 4. Credentials → OAuth 2.0 Client ID banao
# 5. Refresh token generate karo:
#    python -c "
#    from google_auth_oauthlib.flow import InstalledAppFlow
#    flow = InstalledAppFlow.from_client_secrets_file('client_secret.json',
#           scopes=['https://www.googleapis.com/auth/adwords'])
#    creds = flow.run_local_server()
#    print(creds.refresh_token)
#    "
# 6. google-ads.yaml file banao (upar wala template)
# 7. Test manager account ID note karo

# ─── Step 3: Meta Setup ──────────────────────────────────────
# 1. developers.facebook.com → My Apps → Create App
# 2. Marketing API add karo
# 3. App ID + App Secret copy karo
# 4. Graph API Explorer mein jao:
#    developers.facebook.com/tools/explorer
# 5. Permissions add karo:
#    ads_management, ads_read, business_management
# 6. Generate Access Token → Long-lived token banao:
#    GET https://graph.facebook.com/oauth/access_token
#    ?grant_type=fb_exchange_token
#    &client_id={APP_ID}
#    &client_secret={APP_SECRET}
#    &fb_exchange_token={SHORT_LIVED_TOKEN}
# 7. Ad Account ID: Business Manager → Ad Accounts → act_XXXXXXX

# ─── Step 4: services/ folder banao ─────────────────────────
# backend/app/services/__init__.py  ← empty file
# backend/app/services/google_ads_service.py  ← copy karo
# backend/app/services/meta_ads_service.py    ← copy karo

# ─── Step 5: main.py mein router include karo ────────────────
# (already included hoga kyunki campaigns.py update kiya)

# ─── Step 6: Test karo ───────────────────────────────────────
# uvicorn app.main:app --reload
# POST http://localhost:8000/api/campaigns/
# Body: { "name": "Test", "platforms": ["google", "meta"], ... }


# ============================================================
# Test vs Production — SIRF YEH LINES BADLO
# ============================================================
#
# TEST:
# GOOGLE_ADS_CUSTOMER_ID=123-456-7890    ← test account
# META_AD_ACCOUNT_ID=act_test_12345      ← test account
#
# PRODUCTION:
# GOOGLE_ADS_CUSTOMER_ID=987-654-3210    ← client account
# META_AD_ACCOUNT_ID=act_9876543210      ← real account
#
# Baaki sab same! Code mein kuch nahi badlega.
# ============================================================